# ── App ──────────────────────────────────────────────
APP_NAME=AI Data Analyst
APP_VERSION=0.1.0
DEBUG=false

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ─────────────────────────────────────────────
# Frontend dev server URL (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:5173"]

# ── Database (MySQL) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=t2s_analysis

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── LLM ──────────────────────────────────────────────
# Supported: DeepSeek, OpenAI, or any OpenAI-compatible API
# Get your API key at https://platform.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# ── SQL Executor ─────────────────────────────────────
SQL_TIMEOUT=10
SQL_MAX_ROWS=500
