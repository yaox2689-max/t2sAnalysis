# Copy this file to .env and fill in your API key:
#   cp .env.example .env
#
# Only LLM_API_KEY is required. Everything else has working defaults.

# ── LLM (REQUIRED) ────────────────────────────────────
# Get your key at https://platform.deepseek.com
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# ── Database (MySQL) ──────────────────────────────────
# Used for sessions, messages, and dataset metadata.
# Default works with docker-compose.yml
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=root123
DB_NAME=t2s_analysis

# ── Redis ─────────────────────────────────────────────
# Used for session caching. Default works with docker-compose.yml
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── SQL Executor ──────────────────────────────────────
SQL_TIMEOUT=10
SQL_MAX_ROWS=500
